# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/

# Model files
# .pth is OK for git (~14MB), .onnx is produced during build
model/*.onnx

# Streamlit secrets (contains API keys — never commit)
.streamlit/secrets.toml

# Virtual environment
venv/
.venv/
env/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Test images
test_images/

# Training data
data/fresh/*.jpg
data/fresh/*.png
data/rotten/*.jpg
data/rotten/*.png

# But keep the .gitkeep files
!data/fresh/.gitkeep
!data/rotten/.gitkeep
!test_images/.gitkeep